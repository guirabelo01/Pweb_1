<%- include('partials/header') %>

<div class="container py-4" id="app">

  <!-- TELA DE INÍCIO -->
  <div id="tela-inicio" class="text-center py-5">
    <div style="font-size:5rem">🎮</div>
    <h1 class="fw-900 mb-2">BioHabitat Quest</h1>
    <p class="text-muted lead mb-4">Classifique os animais nos habitats corretos!</p>

    <div class="card border-0 shadow mx-auto p-4" style="max-width:420px">
      <h5 class="fw-bold mb-3">Insira seu nome para começar</h5>
      <input type="text" id="input-nome" class="form-control form-control-lg mb-3 text-center"
             placeholder="Seu apelido de jogador" maxlength="30"/>

      <label class="fw-semibold mb-2">Dificuldade:</label>
      <div class="d-flex gap-2 justify-content-center mb-4">
        <button class="btn btn-outline-success btn-dif active-dif" data-dif="facil">😊 Fácil</button>
        <button class="btn btn-outline-warning btn-dif" data-dif="medio">😤 Médio</button>
        <button class="btn btn-outline-danger btn-dif" data-dif="dificil">💀 Difícil</button>
        <button class="btn btn-outline-secondary btn-dif" data-dif="todos">🎲 Todos</button>
      </div>

      <button id="btn-iniciar" class="btn btn-success btn-lg fw-bold w-100">
        <i class="bi bi-play-circle-fill me-2"></i>Iniciar Partida
      </button>
    </div>
  </div>

  <!-- TELA DO JOGO -->
  <div id="tela-jogo" class="d-none">
    <!-- Barra de status -->
    <div class="d-flex justify-content-between align-items-center mb-4 flex-wrap gap-2">
      <div class="d-flex gap-3 align-items-center">
        <span class="badge bg-success fs-6 px-3 py-2"><i class="bi bi-person-fill me-1"></i><span id="hud-nome">—</span></span>
        <span class="badge bg-warning text-dark fs-6 px-3 py-2">⭐ <span id="hud-pontos">0</span> pts</span>
        <span class="badge bg-info text-dark fs-6 px-3 py-2">Nível <span id="hud-nivel">1</span></span>
      </div>
      <div class="d-flex gap-2 align-items-center">
        <span class="badge bg-light text-dark border">✅ <span id="hud-acertos">0</span></span>
        <span class="badge bg-light text-dark border">❌ <span id="hud-erros">0</span></span>
        <span class="badge bg-secondary">Q: <span id="hud-questao">1</span>/10</span>
      </div>
    </div>

    <!-- Timer + Animal card -->
    <div class="text-center mb-4">
      <div class="timer-bar-wrap mb-3">
        <div id="timer-bar" class="timer-bar"></div>
      </div>

      <div class="animal-card card border-0 shadow-lg mx-auto p-4" style="max-width:440px">
        <div id="animal-loading" class="text-muted py-4">
          <div class="spinner-border text-success" role="status"></div>
          <p class="mt-2 mb-0">Carregando...</p>
        </div>
        <div id="animal-content" class="d-none">
          <div id="animal-emoji" style="font-size:5rem">🐾</div>
          <h2 id="animal-nome" class="fw-900 mt-2 mb-1">—</h2>
          <span id="animal-dificuldade" class="badge mb-3">—</span>
          <p class="text-muted small fst-italic" id="animal-hint">Qual habitat é o lar deste animal?</p>
        </div>
      </div>
    </div>

    <!-- Opções de habitat -->
    <div id="opcoes-container" class="row g-3 justify-content-center mb-4" style="max-width:700px;margin:0 auto"></div>

    <!-- Feedback -->
    <div id="feedback" class="text-center d-none mb-3">
      <div id="feedback-card" class="card border-0 shadow mx-auto p-4" style="max-width:480px">
        <div id="feedback-icon" style="font-size:3rem"></div>
        <h4 id="feedback-titulo" class="fw-bold mt-2 mb-1"></h4>
        <p id="feedback-texto" class="mb-3 text-muted"></p>
        <p id="feedback-curiosidade" class="fst-italic small text-muted border-top pt-2 mb-3"></p>
        <button id="btn-proxima" class="btn btn-success fw-bold px-4">
          Próxima <i class="bi bi-arrow-right"></i>
        </button>
      </div>
    </div>
  </div>

  <!-- TELA FIM DE JOGO -->
  <div id="tela-fim" class="d-none text-center py-5">
    <div id="fim-icon" style="font-size:5rem">🏁</div>
    <h1 class="fw-900 mt-2">Partida finalizada!</h1>
    <p class="lead text-muted mb-4">Veja como você se saiu:</p>

    <div class="card border-0 shadow mx-auto p-4 mb-4" style="max-width:420px">
      <div class="row text-center g-3">
        <div class="col-6">
          <div class="text-success display-5 fw-900" id="fim-pontos">0</div>
          <small class="text-muted">Pontuação</small>
        </div>
        <div class="col-6">
          <div class="text-warning display-5 fw-900" id="fim-nivel">1</div>
          <small class="text-muted">Nível</small>
        </div>
        <div class="col-6">
          <div class="text-primary display-5 fw-900" id="fim-acertos">0</div>
          <small class="text-muted">Acertos</small>
        </div>
        <div class="col-6">
          <div class="text-danger display-5 fw-900" id="fim-erros">0</div>
          <small class="text-muted">Erros</small>
        </div>
      </div>
      <div class="mt-3 p-3 bg-light rounded">
        <p class="mb-0 fw-semibold" id="fim-mensagem"></p>
      </div>
    </div>

    <div class="d-flex gap-3 justify-content-center flex-wrap">
      <button id="btn-jogar-novamente" class="btn btn-success btn-lg fw-bold px-4">
        <i class="bi bi-arrow-repeat me-2"></i>Jogar Novamente
      </button>
      <a href="/ranking" class="btn btn-outline-warning btn-lg fw-bold px-4">
        <i class="bi bi-trophy me-2"></i>Ver Ranking
      </a>
    </div>
  </div>

</div>

<script src="/js/jogo.js"></script>
<%- include('partials/footer') %>
