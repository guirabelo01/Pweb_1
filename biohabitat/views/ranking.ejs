<%- include('partials/header') %>

<div class="container py-5">
  <div class="text-center mb-5">
    <h1 class="fw-900 display-5">🏆 Ranking Global</h1>
    <p class="text-muted">Os melhores classificadores de habitat do BioHabitat Quest</p>
  </div>

  <% if (jogadores.length === 0) { %>
    <div class="text-center py-5 text-muted">
      <div style="font-size:4rem">😕</div>
      <h4 class="mt-3">Nenhum jogador ainda!</h4>
      <p>Seja o primeiro a jogar.</p>
      <a href="/jogo" class="btn btn-success fw-bold px-4">Jogar agora</a>
    </div>
  <% } else { %>
    <div class="row justify-content-center">
      <div class="col-lg-8">

        <% jogadores.forEach((j, i) => { %>
          <div class="ranking-card card border-0 shadow-sm mb-3 <%= i === 0 ? 'ranking-ouro' : i === 1 ? 'ranking-prata' : i === 2 ? 'ranking-bronze' : '' %>">
            <div class="card-body d-flex align-items-center gap-3 py-3 px-4">
              <div class="rank-badge fs-3">
                <% if (i === 0) { %>🥇
                <% } else if (i === 1) { %>🥈
                <% } else if (i === 2) { %>🥉
                <% } else { %><span class="text-muted fw-bold">#<%= i+1 %></span><% } %>
              </div>
              <div class="flex-grow-1">
                <h5 class="fw-bold mb-0"><%= j.nome %></h5>
                <small class="text-muted">
                  Nível <%= j.nivel %> · <%= j.partidas %> partida<%= j.partidas !== 1 ? 's' : '' %>
                </small>
              </div>
              <div class="text-end">
                <div class="fs-4 fw-900 text-success"><%= j.pontuacao %> <small class="fs-6">pts</small></div>
                <small class="text-muted">
                  ✅ <%= j.acertos %> &nbsp; ❌ <%= j.erros %>
                </small>
              </div>
            </div>
          </div>
        <% }) %>

      </div>
    </div>

    <div class="text-center mt-4">
      <a href="/jogo" class="btn btn-success btn-lg fw-bold px-5">
        <i class="bi bi-controller me-2"></i>Jogar e subir no ranking
      </a>
    </div>
  <% } %>
</div>

<%- include('partials/footer') %>
