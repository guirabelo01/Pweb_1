<%- include('partials/header') %>

<div class="container py-5">
  <div class="text-center mb-5">
    <h1 class="fw-900 display-5">📖 Documentação da API</h1>
    <p class="text-muted">API REST do BioHabitat — autenticada via API Keys</p>
  </div>

  <div class="row g-4">
    <!-- Chaves da API -->
    <div class="col-lg-4">
      <div class="card border-0 shadow-sm h-100">
        <div class="card-header bg-dark text-white fw-bold">
          🔑 API Keys disponíveis
        </div>
        <div class="card-body">
          <p class="text-muted small">Use uma dessas chaves no header <code>x-api-key</code>:</p>
          <% if(apiKeys.length === 0) { %>
            <p class="text-muted">Nenhuma key. Rode o seed.</p>
          <% } else { %>
            <% apiKeys.forEach(k => { %>
              <div class="mb-3 p-2 bg-light rounded">
                <div class="fw-semibold"><%= k.nome %></div>
                <code class="small text-break"><%= k.key %></code>
                <div class="mt-1">
                  <span class="badge <%= k.ativa ? 'bg-success' : 'bg-danger' %>">
                    <%= k.ativa ? 'Ativa' : 'Inativa' %>
                  </span>
                  <span class="badge bg-secondary ms-1"><%= k.requisicoes %> req.</span>
                </div>
              </div>
            <% }) %>
          <% } %>

          <div class="alert alert-warning small mt-3 mb-0">
            <strong>Como usar:</strong><br/>
            Adicione o header:<br/>
            <code>x-api-key: SUA_CHAVE</code>
          </div>
        </div>
      </div>
    </div>

    <!-- Endpoints -->
    <div class="col-lg-8">
      <div class="card border-0 shadow-sm">
        <div class="card-header bg-dark text-white fw-bold">🚀 Endpoints</div>
        <div class="card-body p-0">

          <!-- Animais -->
          <div class="p-4 border-bottom">
            <h5 class="fw-bold mb-3">🐾 /api/animais</h5>

            <div class="endpoint-item mb-3">
              <span class="badge bg-success me-2">GET</span>
              <code>/api/animais</code>
              <p class="text-muted small mt-1 mb-0">Lista todos os animais. Filtros: <code>?dificuldade=facil|medio|dificil</code> · <code>&busca=nome</code></p>
            </div>

            <div class="endpoint-item mb-3">
              <span class="badge bg-success me-2">GET</span>
              <code>/api/animais/aleatorio</code>
              <p class="text-muted small mt-1 mb-0">Retorna um animal aleatório. Filtro: <code>?dificuldade=facil</code></p>
            </div>

            <div class="endpoint-item mb-3">
              <span class="badge bg-success me-2">GET</span>
              <code>/api/animais/:id</code>
              <p class="text-muted small mt-1 mb-0">Busca animal por ID.</p>
            </div>

            <div class="endpoint-item mb-3">
              <span class="badge bg-primary me-2">POST</span>
              <code>/api/animais</code>
              <p class="text-muted small mt-1 mb-2">Cria um novo animal. Body (JSON):</p>
              <pre class="bg-dark text-light p-3 rounded small"><code>{
  "nome": "Boto-cor-de-rosa",
  "emoji": "🐬",
  "habitatCorreto": "Rio",
  "habitats": ["Rio", "Oceano", "Lago", "Pântano"],
  "curiosidade": "Único golfinho de água doce.",
  "dificuldade": "medio"
}</code></pre>
            </div>

            <div class="endpoint-item mb-3">
              <span class="badge bg-warning text-dark me-2">PUT</span>
              <code>/api/animais/:id</code>
              <p class="text-muted small mt-1 mb-0">Atualiza um animal existente.</p>
            </div>

            <div class="endpoint-item">
              <span class="badge bg-danger me-2">DELETE</span>
              <code>/api/animais/:id</code>
              <p class="text-muted small mt-1 mb-0">Remove um animal.</p>
            </div>
          </div>

          <!-- Jogadores -->
          <div class="p-4">
            <h5 class="fw-bold mb-3">👥 /api/jogadores</h5>

            <div class="endpoint-item mb-3">
              <span class="badge bg-success me-2">GET</span>
              <code>/api/jogadores/ranking</code>
              <p class="text-muted small mt-1 mb-0">Top 10 jogadores por pontuação.</p>
            </div>

            <div class="endpoint-item mb-3">
              <span class="badge bg-success me-2">GET</span>
              <code>/api/jogadores</code>
              <p class="text-muted small mt-1 mb-0">Lista todos os jogadores.</p>
            </div>

            <div class="endpoint-item mb-3">
              <span class="badge bg-primary me-2">POST</span>
              <code>/api/jogadores</code>
              <p class="text-muted small mt-1 mb-0">Cria ou recupera um jogador. Body: <code>{ "nome": "Guilherme" }</code></p>
            </div>

            <div class="endpoint-item mb-3">
              <span class="badge bg-warning text-dark me-2">PUT</span>
              <code>/api/jogadores/:id/pontuacao</code>
              <p class="text-muted small mt-1 mb-0">Atualiza pontuação. Body: <code>{ "acertou": true, "pontos": 150 }</code></p>
            </div>

            <div class="endpoint-item">
              <span class="badge bg-warning text-dark me-2">PUT</span>
              <code>/api/jogadores/:id/finalizar</code>
              <p class="text-muted small mt-1 mb-0">Finaliza a partida (incrementa contador de partidas).</p>
            </div>
          </div>

        </div>
      </div>

      <!-- Exemplo de resposta -->
      <div class="card border-0 shadow-sm mt-4">
        <div class="card-header bg-dark text-white fw-bold">📦 Exemplo de resposta</div>
        <div class="card-body p-0">
          <pre class="bg-dark text-light p-4 rounded-bottom mb-0 small"><code>{
  "sucesso": true,
  "total": 25,
  "dados": [
    {
      "_id": "665abc123...",
      "nome": "Leão",
      "emoji": "🦁",
      "habitatCorreto": "Savana",
      "habitats": ["Savana", "Oceano", "Tundra", "Caverna"],
      "curiosidade": "É o único felino que vive em grupos.",
      "dificuldade": "facil",
      "createdAt": "2024-01-01T00:00:00.000Z"
    }
  ]
}</code></pre>
        </div>
      </div>
    </div>
  </div>
</div>

<%- include('partials/footer') %>
