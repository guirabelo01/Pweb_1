<%- include('partials/header') %>

<div class="container py-5">
  <div class="text-center mb-5">
    <h1 class="fw-900 display-5">🐾 Catálogo de Animais</h1>
    <p class="text-muted">Conheça todos os animais do jogo e seus habitats</p>
  </div>

  <!-- Filtro -->
  <div class="text-center mb-4">
    <div class="btn-group shadow-sm" role="group">
      <a href="/animais?dificuldade=todos" class="btn <%= dificuldade === 'todos' ? 'btn-success' : 'btn-outline-success' %>">🎲 Todos</a>
      <a href="/animais?dificuldade=facil" class="btn <%= dificuldade === 'facil' ? 'btn-success' : 'btn-outline-success' %>">😊 Fácil</a>
      <a href="/animais?dificuldade=medio" class="btn <%= dificuldade === 'medio' ? 'btn-warning' : 'btn-outline-warning' %>">😤 Médio</a>
      <a href="/animais?dificuldade=dificil" class="btn <%= dificuldade === 'dificil' ? 'btn-danger' : 'btn-outline-danger' %>">💀 Difícil</a>
    </div>
  </div>

  <% if (animais.length === 0) { %>
    <div class="text-center py-5 text-muted">
      <div style="font-size:4rem">🔍</div>
      <h4 class="mt-3">Nenhum animal encontrado.</h4>
    </div>
  <% } else { %>
    <div class="row g-4">
      <% animais.forEach(animal => { %>
        <div class="col-sm-6 col-md-4 col-lg-3">
          <div class="animal-catalog-card card border-0 shadow-sm h-100 text-center p-3">
            <div style="font-size:3.5rem"><%= animal.emoji %></div>
            <h5 class="fw-bold mt-2 mb-1"><%= animal.nome %></h5>
            <span class="badge mb-2
              <%= animal.dificuldade === 'facil' ? 'bg-success' : animal.dificuldade === 'medio' ? 'bg-warning text-dark' : 'bg-danger' %>">
              <%= animal.dificuldade === 'facil' ? '😊 Fácil' : animal.dificuldade === 'medio' ? '😤 Médio' : '💀 Difícil' %>
            </span>
            <div class="habitat-tag badge bg-light text-dark border mb-2">
              🌍 <%= animal.habitatCorreto %>
            </div>
            <p class="text-muted small fst-italic mt-auto mb-0"><%= animal.curiosidade %></p>
          </div>
        </div>
      <% }) %>
    </div>
  <% } %>

  <div class="text-center mt-5">
    <a href="/jogo" class="btn btn-success btn-lg fw-bold px-5">
      <i class="bi bi-controller me-2"></i>Agora jogue e acerte todos!
    </a>
  </div>
</div>

<%- include('partials/footer') %>
