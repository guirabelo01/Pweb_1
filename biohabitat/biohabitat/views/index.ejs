<%- include('partials/header') %>

<!-- HERO -->
<section class="hero-section text-white text-center py-5">
  <div class="container py-4">
    <div class="hero-emoji mb-3">🌿</div>
    <h1 class="display-4 fw-900 mb-3">BioHabitat Quest</h1>
    <p class="lead mb-4 mx-auto" style="max-width:560px">
      Você consegue classificar os animais nos habitats corretos?
      Teste seus conhecimentos, suba no ranking e descubra curiosidades incríveis!
    </p>
    <div class="d-flex justify-content-center gap-3 flex-wrap">
      <a href="/jogo" class="btn btn-warning btn-lg fw-bold px-5 py-3 shadow pulse-btn">
        <i class="bi bi-play-circle-fill me-2"></i>Jogar Agora
      </a>
      <a href="/animais" class="btn btn-outline-light btn-lg px-4 py-3">
        <i class="bi bi-grid-fill me-2"></i>Ver Animais
      </a>
    </div>
  </div>
</section>

<!-- STATS -->
<section class="py-5 bg-light">
  <div class="container">
    <div class="row g-4 text-center">
      <div class="col-md-4">
        <div class="stat-card card border-0 shadow-sm h-100 p-4">
          <div class="stat-icon">🐾</div>
          <h2 class="fw-900 text-success display-5"><%= totalAnimais %></h2>
          <p class="text-muted fw-semibold mb-0">Animais cadastrados</p>
        </div>
      </div>
      <div class="col-md-4">
        <div class="stat-card card border-0 shadow-sm h-100 p-4">
          <div class="stat-icon">👥</div>
          <h2 class="fw-900 text-primary display-5"><%= totalJogadores %></h2>
          <p class="text-muted fw-semibold mb-0">Jogadores ativos</p>
        </div>
      </div>
      <div class="col-md-4">
        <div class="stat-card card border-0 shadow-sm h-100 p-4">
          <div class="stat-icon">🏆</div>
          <h2 class="fw-900 text-warning display-5">
            <% if(topJogador){ %><%= topJogador.pontuacao %><% } else { %>—<% } %>
          </h2>
          <p class="text-muted fw-semibold mb-0">
            Recorde: <% if(topJogador){ %><%= topJogador.nome %><% } else { %>Ninguém ainda<% } %>
          </p>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- COMO FUNCIONA -->
<section class="py-5">
  <div class="container">
    <h2 class="text-center fw-900 mb-5">Como funciona?</h2>
    <div class="row g-4">
      <div class="col-md-3 text-center">
        <div class="step-circle mx-auto mb-3">1</div>
        <h5 class="fw-bold">Entre com seu nome</h5>
        <p class="text-muted">Crie seu perfil de jogador para salvar sua pontuação.</p>
      </div>
      <div class="col-md-3 text-center">
        <div class="step-circle mx-auto mb-3">2</div>
        <h5 class="fw-bold">Receba um animal</h5>
        <p class="text-muted">Um animal aparece na tela — fácil, médio ou difícil.</p>
      </div>
      <div class="col-md-3 text-center">
        <div class="step-circle mx-auto mb-3">3</div>
        <h5 class="fw-bold">Escolha o habitat</h5>
        <p class="text-muted">Selecione qual habitat aquele animal pertence.</p>
      </div>
      <div class="col-md-3 text-center">
        <div class="step-circle mx-auto mb-3">4</div>
        <h5 class="fw-bold">Suba no ranking!</h5>
        <p class="text-muted">Acertos valem pontos. Quanto mais difícil, mais pontos!</p>
      </div>
    </div>
  </div>
</section>

<!-- CTA -->
<section class="py-5 bg-success text-white text-center">
  <div class="container">
    <h2 class="fw-900 mb-3">Pronto para jogar? 🎮</h2>
    <p class="lead mb-4">Já temos <%= totalAnimais %> animais esperando por você!</p>
    <a href="/jogo" class="btn btn-warning btn-lg fw-bold px-5">
      <i class="bi bi-lightning-fill me-2"></i>Começar agora
    </a>
  </div>
</section>

<%- include('partials/footer') %>
